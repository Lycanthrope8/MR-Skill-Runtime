# MR-Skill-Runtime configuration
# Copy this file to `.env` and fill in values. Do NOT commit `.env`.

# --- Skill assets -----------------------------------------------------------
# Absolute or relative path to a CHECKOUT of MR-Skill-Assets, pointed at the
# specific skill subdirectory you want to load. The runtime computes the
# skillManifestHash from the manifest.json inside this path at startup.
SKILL_ASSETS_PATH=../MR-Skill-Assets/spatial-governance-skill

# --- LLM provider selection -----------------------------------------------
# Single switch — restart the runtime after changing.
# Options:
#   parley     remote: Kennesaw State BYOK gateway (GPT-5, o-series, etc.)
#   local      self-hosted: Ollama, llama.cpp, LM Studio, or vLLM
LLM_PROVIDER=parley

# --- Parley settings (used when LLM_PROVIDER=parley) -----------------------
PARLEY_BASE_URL=https://keys.theparley.org/v1
PARLEY_API_KEY=replace-with-your-parley-key
PARLEY_MODEL=gpt-5.1
PARLEY_MAX_OUTPUT_TOKENS=2048
PARLEY_TIMEOUT_MS=60000

# --- Local LLM settings (used when LLM_PROVIDER=local) ---------------------
# For Ollama (default): http://localhost:11434/v1
# For llama.cpp server:  http://localhost:8080/v1
# For LM Studio:         http://localhost:1234/v1
# For vLLM:              http://localhost:8000/v1
LOCAL_LLM_BASE_URL=http://localhost:11434/v1

# Model name as exposed by the server.
# For Ollama, this is the tag from `ollama list`. Examples:
#   qwen2.5:7b-instruct-q4_K_M     ← recommended for 6GB VRAM
#   llama3.1:8b-instruct-q4_K_M    ← alternative for 6GB VRAM
#   qwen2.5:14b-instruct-q4_K_M    ← 8-12GB VRAM
#   llama3.2:3b-instruct-q4_K_M    ← fallback if 7B is unstable
LOCAL_LLM_MODEL=qwen2.5:7b-instruct-q4_K_M

# Most local servers don't need a key. Leave blank unless you've put auth
# in front of yours (e.g. nginx with HTTP basic auth).
LOCAL_LLM_API_KEY=

# Local models can be slower than cloud APIs. 2 minutes is generous.
LOCAL_LLM_TIMEOUT_MS=120000

# Smaller models are more sensitive to temperature. 0.2 keeps outputs stable
# without making them robotic. Use 0 if you see the model deviating from the
# Decision JSON contract.
LOCAL_LLM_TEMPERATURE=0.2

LOCAL_LLM_MAX_OUTPUT_TOKENS=2048

# --- Server ---------------------------------------------------------------
PORT=5100
HOST=127.0.0.1

# --- Logging --------------------------------------------------------------
LOG_LEVEL=info
