# MR-Skill-Runtime configuration
# Copy this file to `.env` and fill in values. Do NOT commit `.env`.

# --- Skill assets -----------------------------------------------------------
# Absolute or relative path to a CHECKOUT of MR-Skill-Assets, pointed at the
# specific skill subdirectory you want to load. The runtime computes the
# skillManifestHash from the manifest.json inside this path at startup.
#
# Per the Phase 2 decision: env-var sourcing (no submodule).
# Recommended layout:
#   ~/code/journal-extension/MR-Skill-Assets/          (sibling repo, tag v0.1.0)
#   ~/code/journal-extension/MR-Skill-Runtime/.env     (this file)
SKILL_ASSETS_PATH=../MR-Skill-Assets/spatial-governance-skill

# --- LLM provider ----------------------------------------------------------
# Phase 2 uses a single provider: Parley.
LLM_PROVIDER=parley

# Parley settings. Base URL confirmed from the dashboard.
PARLEY_BASE_URL=https://keys.theparley.org/v1
PARLEY_API_KEY=replace-with-your-parley-key
# Pin a specific model id. GPT-5 / o-series reasoning models are supported;
# the adapter auto-detects and uses max_completion_tokens for those.
# Examples (use the exact id shown in your Parley dashboard):
#   gpt-5
#   gpt-5-mini
#   o3
#   o4-mini
PARLEY_MODEL=gpt-5

# Optional: cap output budget. For reasoning models this becomes
# max_completion_tokens; for chat models it becomes max_tokens.
PARLEY_MAX_OUTPUT_TOKENS=2048

# Optional: request timeout in ms (reasoning models can be slow on first token)
PARLEY_TIMEOUT_MS=60000

# --- Server ----------------------------------------------------------------
# Phase 2 ships a server but it isn't wired to the gateway yet.
# Phase 4 will use it.
PORT=5100
HOST=127.0.0.1

# --- Logging ---------------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info
